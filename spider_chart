{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 500,
  "height": 500,

  "autosize": { "type": "pad", "contains": "padding" },
  "padding": { "top": 30, "left": 30, "right": 30, "bottom": 70 },

  "data": { "name": "dataset" },

  "transform": [
    {
      "aggregate": [
        { "op": "mean", "field": "Waarde", "as": "WaardeAgg" }
      ],
      "groupby": ["groep", "aangepast"]
    },

    {
      "calculate": "datum.aangepast == '1. Werkhouding / taakaanpak' ? 1 : datum.aangepast == '2. Sociaal-emotioneel / gedrag' ? 2 : datum.aangepast == '3. Context / systeem' ? 3 : datum.aangepast == '4. Fysiek / motorisch' ? 4 : datum.aangepast == '5. Communicatie / taal' ? 5 : datum.aangepast == '6. Leren / cognitief' ? 6 : null",
      "as": "catIndex"
    },

    { "calculate": "6", "as": "catCount" },

    {
      "calculate": "2 * PI * (datum.catIndex - 1) / datum.catCount - PI / 2",
      "as": "angle"
    },

    { "calculate": "datum.WaardeAgg", "as": "r" },
    { "calculate": "datum.r * cos(datum.angle)", "as": "x" },
    { "calculate": "-datum.r * sin(datum.angle)", "as": "y" }
  ],

  "layer": [

    /* === GRID === */
    {
      "data": {
        "values": [
          { "r": 1, "i": 1 }, { "r": 1, "i": 2 }, { "r": 1, "i": 3 }, { "r": 1, "i": 4 }, { "r": 1, "i": 5 }, { "r": 1, "i": 6 },
          { "r": 2, "i": 1 }, { "r": 2, "i": 2 }, { "r": 2, "i": 3 }, { "r": 2, "i": 4 }, { "r": 2, "i": 5 }, { "r": 2, "i": 6 },
          { "r": 3, "i": 1 }, { "r": 3, "i": 2 }, { "r": 3, "i": 3 }, { "r": 3, "i": 4 }, { "r": 3, "i": 5 }, { "r": 3, "i": 6 },
          { "r": 4, "i": 1 }, { "r": 4, "i": 2 }, { "r": 4, "i": 3 }, { "r": 4, "i": 4 }, { "r": 4, "i": 5 }, { "r": 4, "i": 6 },
          { "r": 5, "i": 1 }, { "r": 5, "i": 2 }, { "r": 5, "i": 3 }, { "r": 5, "i": 4 }, { "r": 5, "i": 5 }, { "r": 5, "i": 6 },
          { "r": 6, "i": 1 }, { "r": 6, "i": 2 }, { "r": 6, "i": 3 }, { "r": 6, "i": 4 }, { "r": 6, "i": 5 }, { "r": 6, "i": 6 }
        ]
      },
      "transform": [
        { "calculate": "6", "as": "catCount" },
        {
          "calculate": "-2 * PI * (datum.i - 1) / datum.catCount - PI / 2",
          "as": "angle"
        },
        { "calculate": "datum.r * cos(datum.angle)", "as": "x" },
        { "calculate": "-datum.r * sin(datum.angle)", "as": "y" }
      ],
      "mark": {
        "type": "line",
        "interpolate": "linear-closed",
        "stroke": "#B0B0B0",
        "strokeWidth": 1
      },
      "encoding": {
        "x": { "field": "x", "type": "quantitative", "scale": { "domain": [-9.8, 9.8] }, "axis": null },
        "y": { "field": "y", "type": "quantitative", "scale": { "domain": [-9.8, 9.8] }, "axis": null },
        "detail": { "field": "r" },
        "order": { "field": "i" }
      }
    },

    /* === DATA LIJNEN === */
    {
      "mark": {
        "type": "line",
        "interpolate": "linear-closed",
        "point": true,
        "strokeWidth": 2
      },
      "encoding": {
        "x": { "field": "x", "type": "quantitative", "scale": { "domain": [-9.8, 9.8] }, "axis": null },
        "y": { "field": "y", "type": "quantitative", "scale": { "domain": [-9.8, 9.8] }, "axis": null },
        "stroke": {
          "field": "groep",
          "type": "nominal",
          "legend": {
            "title": "Legenda",
            "orient": "bottom",
            "direction": "horizontal",
            "columns": 3,
            "symbolType": "stroke"
          }
        },
        "detail": { "field": "groep" },
        "order": { "field": "catIndex" }
      }
    },

    /* === RADIUS LABELS === */
    {
      "data": {
        "values": [{ "r": 1 }, { "r": 2 }, { "r": 3 }, { "r": 4 }, { "r": 5 }, { "r": 6 }]
      },
      "transform": [
        { "calculate": "0", "as": "x" },
        { "calculate": "-datum.r", "as": "y" }
      ],
      "mark": {
        "type": "text",
        "fontSize": 11,
        "fill": "#666",
        "baseline": "bottom",
        "align": "center"
      },
      "encoding": {
        "x": { "field": "x", "type": "quantitative", "axis": null },
        "y": { "field": "y", "type": "quantitative", "axis": null },
        "text": { "field": "r" }
      }
    },

    /* === CATEGORIE LABELS (HALO) === */
    {
      "transform": [
        {
          "aggregate": [{ "op": "max", "field": "angle", "as": "angle" }],
          "groupby": ["aangepast", "catIndex"]
        },
        { "calculate": "9.2 * cos(datum.angle)", "as": "x" },
        { "calculate": "-9.2 * sin(datum.angle)", "as": "y" }
      ],
      "mark": {
        "type": "text",
        "fontSize": 14,
        "fill": "white",
        "align": "center",
        "baseline": "middle"
      },
      "encoding": {
        "x": { "field": "x", "type": "quantitative", "axis": null },
        "y": { "field": "y", "type": "quantitative", "axis": null },
        "text": { "field": "aangepast" }
      }
    },

    /* === CATEGORIE LABELS (VOORGROND) === */
    {
      "transform": [
        {
          "aggregate": [{ "op": "max", "field": "angle", "as": "angle" }],
          "groupby": ["aangepast", "catIndex"]
        },
        { "calculate": "9.2 * cos(datum.angle)", "as": "x" },
        { "calculate": "-9.2 * sin(datum.angle)", "as": "y" }
      ],
      "mark": {
        "type": "text",
        "fontSize": 11,
        "fontWeight": "bold",
        "fill": "#333",
        "align": "center",
        "baseline": "middle"
      },
      "encoding": {
        "x": { "field": "x", "type": "quantitative", "axis": null },
        "y": { "field": "y", "type": "quantitative", "axis": null },
        "text": { "field": "aangepast" }
      }
    }
  ],

  "view": { "stroke": null }
}
